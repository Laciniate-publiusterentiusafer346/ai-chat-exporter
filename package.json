{
  "name": "ai-chat-exporter",
  "displayName": "AI Chat Exporter",
  "version": "1.0.0",
  "description": "Export conversations from ChatGPT, Gemini, Claude, DeepSeek, and Grok to PDF and Markdown files",
  "author": "AI Chat Exporter Contributors",
  "license": "MIT",
  "scripts": {
    "dev": "plasmo dev",
    "build": "bash scripts/build-all.sh",
    "package": "plasmo package",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "plasmo": "^0.89.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "jsdom": "^24.0.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  },
  "manifest": {
    "permissions": [
      "storage",
      "activeTab",
      "downloads",
      "alarms",
      "tabs"
    ],
    "host_permissions": [
      "https://chatgpt.com/*",
      "https://chat.openai.com/*",
      "https://claude.ai/*",
      "https://deepseek.com/*",
      "https://chat.deepseek.com/*",
      "https://gemini.google.com/*",
      "https://grok.com/*",
      "https://www.grok.com/*"
    ],
    "browser_specific_settings": {
      "gecko": {
        "id": "ai-chat-exporter@pinguarmy.github.io",
        "strict_min_version": "109.0"
      }
    }
  }
}
